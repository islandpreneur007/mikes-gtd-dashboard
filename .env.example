# Notion integration token — read/write access to the 6 GTD databases.
# Get one at https://www.notion.so/profile/integrations
NOTION_API_KEY=secret_xxx

# Shared-secret token required on every /api/notion request via X-Auth-Token.
# Pick anything high-entropy (e.g. `openssl rand -base64 32`). The dashboard
# stores this in localStorage per device under the key `gtd-token`.
GTD_AUTH_TOKEN=replace-me-with-a-strong-random-string
